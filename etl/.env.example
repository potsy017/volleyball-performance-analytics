# Copy to .env and fill in. Never commit .env.

# --- Catapult Connect (OpenField) ---
CATAPULT_TOKEN=
CATAPULT_BASE_URL=https://connect-au.catapultsports.com/api/v6
# bulk_export.py: default activity cap (0 = no cap). Override with: python bulk_export.py --all
# CATAPULT_BULK_EXPORT_LIMIT=100
# Load index: python load_index.py --start YYYY-MM-DD --end YYYY-MM-DD
# CATAPULT_LOAD_INDEX_START=
# CATAPULT_LOAD_INDEX_END=
# CATAPULT_API_PAUSE=0.5
# LOAD_INDEX_JSON_OUT=load_index_result.json

# --- GymAware Cloud (HTTP Basic: Account ID + API token) ---
# https://gymaware.com/gymaware-cloud-api-integration-guide/
GYMAWARE_ACCOUNT_ID=
GYMAWARE_TOKEN=
# Optional override (default https://cloud.gymaware.com/api):
# GYMAWARE_BASE_URL=https://cloud.gymaware.com/api
# Export script (gymaware_export.py) — UTC dates inclusive:
# GYMAWARE_EXPORT_START=2026-01-01
# GYMAWARE_EXPORT_END=2026-01-31
# gymaware_export.py exports summaries + reps + athletes + bests by default (use --skip-* to omit)
# GYMAWARE_REPS_EXPORT_FILE=gymaware_reps_export.json
# GYMAWARE_ATHLETES_EXPORT_FILE=gymaware_athletes_export.json
# GYMAWARE_BESTS_EXPORT_FILE=gymaware_bests_export.json
# /bests date-window chunk size in days (API max ~3 months per call; default 90 — adjust if needed)
# GYMAWARE_BESTS_CHUNK_DAYS=90
# Optional: path to beach VB allowlist workbook (default: ./GymAware API Reference Numbers.xlsx)
# GYMAWARE_ALLOWLIST_XLSX=
# Set to 1 to filter GymAware export + upload to athlete IDs in the workbook (privacy / roster scope)
# GYMAWARE_USE_ALLOWLIST=0
#
# Unified confirmed roster (recommended): when ROSTER_FILTER=1, GymAware/Catapult/VALD/WHOOP ETL
# only ingest data for athletes in the workbook; point ROSTER_ALLOWLIST_XLSX at the client file
# (sheet "GymAware": Last Name, First Name, GymAware API ID, Vald Profile_ID, ...).
# Catapult filtering: use workbook column 'Catapult Jerseys' (matches API athlete_jersey), and/or
# public.athlete_identity.catapult_athlete_id when your tenant exposes stable athlete UUIDs.
# WHOOP ETL keeps tokens whose state_label matches a roster GymAware ID.
# ROSTER_FILTER=0
# Omit ROSTER_ALLOWLIST_XLSX to use committed data/roster/roster_new.xlsx (same as GitHub Actions).
# ROSTER_ALLOWLIST_XLSX=data/roster/roster_new.xlsx
# Local OneDrive copy coaches edited:
# ROSTER_ALLOWLIST_XLSX=D:\CursorProjects\Volley\roster_new.xlsx
# SCHEDULED_SKIP_ROSTER_SYNC=1

# --- Supabase / Postgres ---
# Local dev: direct connection (db.<ref>.supabase.co:5432) is fine.
# GitHub Actions / Render / Railway: use Session pooler URI from Supabase → Database → Connect
#   (aws-0-<region>.pooler.supabase.com:5432, user postgres.<ref>) — avoids IPv6 failures in CI.
DATABASE_URL=

# --- WHOOP (OAuth 2.0 — Auth Bridge on Render or local) ---
# https://developer.whoop.com/docs/developing/getting-started
# WHOOP_CLIENT_ID=
# WHOOP_CLIENT_SECRET=
# Must match the callback route exactly (register in WHOOP Developer Dashboard):
# WHOOP_REDIRECT_URI=https://<your-service>.onrender.com/callback
# Optional space-separated scopes (default includes offline + read:profile + metrics):
# WHOOP_SCOPES=offline read:profile read:recovery read:cycles read:sleep read:workout read:body_measurement
# Start URL (after deploy): https://<your-service>.onrender.com/whoop/start?state=<8+ char label>
# ETL (schedule whoop_etl.py; requires schema/whoop_staging.sql):
# WHOOP_ETL_LOOKBACK_DAYS=14
# WHOOP_ETL_RESOURCES=sleep,workout,cycle,recovery
# Multi-source orchestrator (python scheduled_etl.py --all):
# SCHEDULED_GYMAWARE_LOOKBACK_DAYS=7
# SCHEDULED_WHOOP_LOOKBACK_DAYS=14
# SCHEDULED_LOAD_INDEX_LOOKBACK_DAYS=7
# Legacy / manual testing (not for production bridge):
# WHOOP_ACCESS_TOKEN=
# WHOOP_REFRESH_TOKEN=
#
# --- VALD (client credentials + regional APIs) ---
# Request access: support@vald.com with Organization ID from VALD Hub.
# https://support.vald.com/hc/en-au/articles/23415335574553-How-to-integrate-with-VALD-APIs
# VALD_CLIENT_ID=
# VALD_CLIENT_SECRET=
# Token endpoint (confirm region with VALD; example from docs):
# VALD_OAUTH_TOKEN_URL=https://auth.prd.vald.com/oauth/token
# VALD_OAUTH_AUDIENCE=vald-api-external
# Regional API hosts (Australia East defaults; override for USE/EUW):
# VALD_API_BASE_TENANTS=https://prd-aue-api-externaltenants.valdperformance.com
# VALD_API_BASE_PROFILE=https://prd-aue-api-externalprofile.valdperformance.com
# VALD_ORGANIZATION_ID=   # from VALD Hub — reference only until wired into scripts
# VALD_REGION=AUE
# Run: python vald_export.py
# Force plate test summaries (activity metrics — not Profiles API). AUE default; confirm Swagger for your region:
# VALD_API_BASE_FORCEFRAME=https://prd-aue-api-externalforceframe.valdperformance.com
# Ingest: python upload_vald_forceframe_tests_to_supabase.py (also runs after profiles in scheduled_etl.py)
# SCHEDULED_VALD_FORCEFRAME_LOOKBACK_DAYS=7
# VALD_SKIP_FORCEFRAME_TESTS=0
#
# ForceDecks (Volleyball AU / Uni package grain — tests + trials + metric defs). valdr uses same regional host pattern:
# VALD_API_BASE_FORCEDECKS=https://prd-aue-api-extforcedecks.valdperformance.com
# python upload_vald_forcedecks_to_supabase.py
# SCHEDULED_VALD_FORCEDECKS_LOOKBACK_DAYS=7
# VALD_FORCEDECKS_TEAM_ID=   # UUID — enables GET .../tests/detailed/... → trials (VA_VALD_Trials equivalent)
# VALD_FORCEDECKS_SYNC_DEFINITIONS=0
# VALD_SKIP_FORCEDECKS=0
# Entity model hints: docs/volley-etl/vald_va_package_notes.md
#
# --- Teamworks AMS ---
# Obtain tenant API credentials from Teamworks; auth scheme is in Postman collection:
# https://documenter.getpostman.com/view/31794560/2sA3rzJs2V
# TEAMWORKS_AMS_BASE_URL=
# TEAMWORKS_AMS_CLIENT_ID=
# TEAMWORKS_AMS_CLIENT_SECRET=
# (or API key / bearer — follow Postman for your tenant)

# Optional: R jump export default output
# JUMP_EXPORT_XLSX=jump_spreadsheet.xlsx
