# Dashboard API — copy to backend/.env (never commit)

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Demo / local: skip JWT checks (do not use in production with sensitive data)
AUTH_ENABLED=false

# Production login: set AUTH_ENABLED=true and fill SUPABASE_JWT_SECRET
SUPABASE_JWT_SECRET=

# Comma-separated origins, or * for open demo API
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional
SECRET_KEY=change-me
DATA_SOURCE=supabase
GMAIL_USER=
GMAIL_APP_PASSWORD=
ADMIN_EMAIL=
