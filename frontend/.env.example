# Copy to frontend/.env.local (gitignored) for local dev with Supabase auth / MFA.
# Use the anon (public) key from Supabase → Project Settings → API — not the service role key.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Local dev without login (gitignored .env.local only; do not set in production):
# VITE_AUTH_DISABLED=true

# Optional: override API base (default: Vite proxy /api → :8000)
# VITE_API_URL=http://127.0.0.1:8000/api
